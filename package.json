{
  "name": "timds",
  "version": "0.0.1",
  "description": "Biblioteca de componentes React com design system embutido (shadcn/ui + Tailwind).",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "ai",
    "mcp",
    "scripts/generate-ai-docs.mjs"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "timds-mcp": "./mcp/timds-mcp.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/timds.css",
    "./ai/manifest.json": "./ai/manifest.json",
    "./ai/llms.txt": "./ai/llms.txt",
    "./ai/llms-full.txt": "./ai/llms-full.txt"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project=unit",
    "test:storybook": "vitest run --project=storybook",
    "coverage": "vitest run --coverage",
    "storybook": "set -a; [ -f .env.local ] && . ./.env.local; set +a; storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "set -a; [ -f .env.local ] && . ./.env.local; set +a; chromatic",
    "ai:docs": "node scripts/generate-ai-docs.mjs",
    "mcp:build": "node scripts/build-mcp.mjs",
    "mcp": "node mcp/server.mjs",
    "prebuild": "node scripts/generate-ai-docs.mjs && node scripts/build-mcp.mjs",
    "prepare": "node scripts/generate-ai-docs.mjs && node scripts/build-mcp.mjs && vite build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "recharts": ">=3"
  },
  "peerDependenciesMeta": {
    "recharts": {
      "optional": true
    }
  },
  "dependencies": {
    "@ariakit/react": "^0.4.29",
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-virtual": "^3.14.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.20.0",
    "match-sorter": "^8.3.0",
    "radix-ui": "^1.6.0",
    "react-day-picker": "^10.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@chromatic-com/storybook": "^5.2.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "chromatic": "^17.5.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.0",
    "shadcn": "^4.11.0",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  }
}
